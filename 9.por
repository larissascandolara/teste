programa {
  funcao inicio() {
    //Leia três números e mostre a média.

    inteiro n1,n2,n3, media
    escreva("primeiro numero:")
    leia(n1)
    escreva("segundo numero:")
    leia(n2)
    escreva("terceiro numero:")
    leia(n3)

    media=( n1+n2+n3) /3

    escreva("media:",media)

    

  }
}
